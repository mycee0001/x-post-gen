# TwitterAPI.io (https://twitterapi.io/dashboard)
TWITTERAPI_IO_KEY=

# Tavily Search API (https://app.tavily.com/home)
TAVILY_API_KEY=

# オプション: 履歴管理の設定
X_HISTORY_RETENTION_DAYS=30          # 重複チェックの期間
X_HISTORY_SIMHASH_THRESHOLD=4        # 本文類似度(ハミング距離)の閾値

# オプション: 1回のコマンドで生成するバリエーション数 (デフォルト 5)
X_POST_VARIANTS=5
X_QUOTE_VARIANTS=5
